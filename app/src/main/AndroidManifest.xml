<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />
    <!-- Exact alarms for the sleep timer & scene schedules. USE_EXACT_ALARM (API 33+) is granted by
         default for timer/alarm-clock apps so the sleep timer fires reliably without the user having to
         flip a setting; SCHEDULE_EXACT_ALARM covers API 31/32. / Exakte Alarme für Sleep-Timer &
         Szenen-Zeitpläne. USE_EXACT_ALARM (ab API 33) ist für Timer-/Wecker-Apps standardmäßig erteilt,
         damit der Sleep-Timer ohne Nutzer-Einstellung zuverlässig auslöst; SCHEDULE_EXACT_ALARM deckt API 31/32. -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Live sleep-timer countdown notification with off-now/cancel actions (Android 13+) / Live-Countdown-Benachrichtigung des Sleep-Timers mit Jetzt-aus/Abbrechen (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MideaControl">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MideaControl">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Invisible trampoline for launcher shortcuts that perform an action (off / scene) / Unsichtbares Trampolin für Launcher-Shortcuts, die eine Aktion ausführen (Aus / Szene) -->
        <activity
            android:name=".ShortcutActionActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- Applies a scheduled scene when its daily alarm fires / Wendet eine geplante Szene an, wenn ihr Tagesalarm auslöst -->
        <receiver
            android:name=".SceneAlarmReceiver"
            android:exported="false" />

        <!-- Powers the unit off when the sleep timer fires, even with the app closed / Schaltet das Gerät aus, wenn der Sleep-Timer auslöst, auch bei geschlossener App -->
        <receiver
            android:name=".SleepTimerReceiver"
            android:exported="false" />

        <!-- Handles the off-now / cancel buttons on the sleep-timer countdown notification / Verarbeitet die Jetzt-aus/Abbrechen-Knöpfe der Sleep-Timer-Countdown-Benachrichtigung -->
        <receiver
            android:name=".TimerActionReceiver"
            android:exported="false" />

        <!-- Re-arms scene schedules after a reboot / Stellt Szenen-Zeitpläne nach einem Neustart wieder her -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- All-in-one widget: name, temperature, power/±/mode + status, offline / Alles-Widget: Name, Temperatur, Ein-Aus/±/Modus + Status, offline.
             Also the central control hub the purpose-built widgets broadcast their actions to / zugleich die zentrale Steuerstelle, an die die zweckgebundenen Widgets ihre Aktionen senden. -->
        <receiver
            android:name=".widget.AcWidgetProvider"
            android:exported="false"
            android:label="@string/widget_all_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.climapilot.free.widget.POWER" />
                <action android:name="com.climapilot.free.widget.TEMP_UP" />
                <action android:name="com.climapilot.free.widget.TEMP_DOWN" />
                <action android:name="com.climapilot.free.widget.MODE" />
                <action android:name="com.climapilot.free.widget.SET_MODE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_ac_info" />
        </receiver>

        <!-- Power-only widget / Reines Ein/Aus-Widget -->
        <receiver
            android:name=".widget.AcWidgetPowerProvider"
            android:exported="false"
            android:label="@string/widget_power_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_power_info" />
        </receiver>

        <!-- Temperature-only widget / Reines Temperatur-Widget -->
        <receiver
            android:name=".widget.AcWidgetTempProvider"
            android:exported="false"
            android:label="@string/widget_temp_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_temp_info" />
        </receiver>

        <!-- Mode-only widget / Reines Modus-Widget -->
        <receiver
            android:name=".widget.AcWidgetModeProvider"
            android:exported="false"
            android:label="@string/widget_mode_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_mode_info" />
        </receiver>

        <!-- Receives control commands from the Wear OS watch app over the Data Layer / Empfängt Steuerbefehle der Wear-OS-Watch-App über den Data-Layer -->
        <service
            android:name=".WearListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/climapilot" />
            </intent-filter>
        </service>

        <!-- Quick Settings tile: toggle AC power from the shade, offline / Schnelleinstellungen-Kachel: Klima aus der Statusleiste ein/aus, offline -->
        <service
            android:name=".PowerTileService"
            android:exported="true"
            android:icon="@drawable/ic_w_power"
            android:label="@string/tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Quick Settings tile: cycle the AC mode from the shade, offline / Schnelleinstellungen-Kachel: Klima-Modus aus der Statusleiste durchschalten, offline -->
        <service
            android:name=".ModeTileService"
            android:exported="true"
            android:icon="@drawable/ic_w_mode"
            android:label="@string/tile_mode_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>
    </application>

</manifest>
