<?xml version="1.0" encoding="utf-8"?>
<!-- EN: Mode-picker widget metadata (current mode + all five mode chips). DE: Metadaten für das Modus-Auswahl-Widget (aktueller Modus + alle fünf Modus-Chips). -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="110dp"
    android:targetCellWidth="4"
    android:targetCellHeight="2"
    android:updatePeriodMillis="1800000"
    android:initialLayout="@layout/widget_mode"
    android:previewLayout="@layout/widget_mode"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:description="@string/widget_mode_desc" />
