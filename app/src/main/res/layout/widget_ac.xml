<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="16dp"
    android:theme="@android:style/Theme.DeviceDefault">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_name"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Midea" />

        <ImageButton
            android:id="@+id/btn_mode"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/widget_btn_bg"
            android:src="@drawable/ic_w_mode"
            android:contentDescription="@string/widget_mode"
            android:scaleType="centerInside" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp">

        <TextView
            android:id="@+id/widget_temp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="40sp"
            android:textStyle="bold"
            android:text="24°" />

        <ImageButton
            android:id="@+id/btn_minus"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/widget_btn_bg"
            android:src="@drawable/ic_w_minus"
            android:contentDescription="@string/widget_cool_down"
            android:scaleType="centerInside" />

        <ImageButton
            android:id="@+id/btn_power"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/widget_btn_bg"
            android:src="@drawable/ic_w_power"
            android:contentDescription="@string/widget_power"
            android:scaleType="centerInside" />

        <ImageButton
            android:id="@+id/btn_plus"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/widget_btn_bg"
            android:src="@drawable/ic_w_plus"
            android:contentDescription="@string/widget_warm_up"
            android:scaleType="centerInside" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#D8FFFFFF"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="" />

</LinearLayout>
