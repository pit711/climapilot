<?xml version="1.0" encoding="utf-8"?>
<!--
  EN: All-in-one widget. Power button centered on top (the hero) with a small connection dot in the
      corner; temperature with − / + below; all five modes as chips at the bottom (active highlighted,
      each selects its mode directly); a slim status line (indoor · power / off).
  DE: Alles-Widget. Power-Knopf mittig oben (der Hero) mit kleinem Verbindungspunkt in der Ecke;
      Temperatur mit − / + darunter; alle fünf Modi als Chips unten (aktiver hervorgehoben, jeder wählt
      seinen Modus direkt); eine schlanke Statuszeile (Innen · Leistung / aus).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="16dp"
    android:theme="@android:style/Theme.DeviceDefault">

    <!-- Header: power centered, connection dot in the top-right corner -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- EN: Must be an ImageView, not a bare <View>: RemoteViews can only inflate @RemoteView-annotated
             classes, so a plain View throws "Problem loading widget" in the launcher process.
             DE: Muss eine ImageView sein, kein nacktes <View>: RemoteViews kann nur @RemoteView-annotierte
             Klassen inflaten, ein einfaches View wirft „Problem beim Laden des Widgets" im Launcher-Prozess. -->
        <ImageView
            android:id="@+id/widget_dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="2dp"
            android:contentDescription="@null"
            android:background="@drawable/widget_dot_off" />

        <ImageButton
            android:id="@+id/btn_power"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/widget_btn_bg"
            android:src="@drawable/ic_w_power"
            android:contentDescription="@string/widget_power"
            android:scaleType="centerInside" />
    </FrameLayout>

    <!-- Temperature: − 24° + -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="12dp">

        <ImageButton
            android:id="@+id/btn_minus"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/widget_btn_bg"
            android:src="@drawable/ic_w_minus"
            android:contentDescription="@string/widget_cool_down"
            android:scaleType="centerInside" />

        <TextView
            android:id="@+id/widget_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="22dp"
            android:layout_marginEnd="22dp"
            android:minWidth="96dp"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="44sp"
            android:textStyle="bold"
            android:text="24°" />

        <ImageButton
            android:id="@+id/btn_plus"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/widget_btn_bg"
            android:src="@drawable/ic_w_plus"
            android:contentDescription="@string/widget_warm_up"
            android:scaleType="centerInside" />
    </LinearLayout>

    <!-- Mode chips -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="14dp">

        <TextView
            android:id="@+id/mode_auto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:paddingTop="9dp"
            android:paddingBottom="9dp"
            android:gravity="center"
            android:background="@drawable/widget_chip_bg"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="@string/mode_auto" />

        <TextView
            android:id="@+id/mode_cool"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:paddingTop="9dp"
            android:paddingBottom="9dp"
            android:gravity="center"
            android:background="@drawable/widget_chip_bg"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="@string/mode_cool" />

        <TextView
            android:id="@+id/mode_dry"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:paddingTop="9dp"
            android:paddingBottom="9dp"
            android:gravity="center"
            android:background="@drawable/widget_chip_bg"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="@string/mode_dry" />

        <TextView
            android:id="@+id/mode_heat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:paddingTop="9dp"
            android:paddingBottom="9dp"
            android:gravity="center"
            android:background="@drawable/widget_chip_bg"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="@string/mode_heat" />

        <TextView
            android:id="@+id/mode_fan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingTop="9dp"
            android:paddingBottom="9dp"
            android:gravity="center"
            android:background="@drawable/widget_chip_bg"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="@string/mode_fan" />
    </LinearLayout>

    <!-- Status -->
    <TextView
        android:id="@+id/widget_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:textColor="#A8FFFFFF"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="" />

</LinearLayout>
