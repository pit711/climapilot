<?xml version="1.0" encoding="utf-8"?>
<!--
  EN: Mode widget. Shows the current mode on top, then a row of all five modes as chips; tapping a
      chip selects that mode directly (and powers the unit on). The active mode is highlighted.
  DE: Modus-Widget. Zeigt oben den aktuellen Modus, darunter alle fünf Modi als Chips; ein Tippen wählt
      den Modus direkt (und schaltet das Gerät ein). Der aktive Modus ist hervorgehoben.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_vertical"
    android:background="@drawable/widget_bg"
    android:padding="14dp"
    android:theme="@android:style/Theme.DeviceDefault">

    <TextView
        android:id="@+id/widget_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="10dp">

        <TextView
            android:id="@+id/mode_auto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:paddingTop="9dp"
            android:paddingBottom="9dp"
            android:gravity="center"
            android:background="@drawable/widget_chip_bg"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="@string/mode_auto" />

        <TextView
            android:id="@+id/mode_cool"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:paddingTop="9dp"
            android:paddingBottom="9dp"
            android:gravity="center"
            android:background="@drawable/widget_chip_bg"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="@string/mode_cool" />

        <TextView
            android:id="@+id/mode_dry"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:paddingTop="9dp"
            android:paddingBottom="9dp"
            android:gravity="center"
            android:background="@drawable/widget_chip_bg"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="@string/mode_dry" />

        <TextView
            android:id="@+id/mode_heat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:paddingTop="9dp"
            android:paddingBottom="9dp"
            android:gravity="center"
            android:background="@drawable/widget_chip_bg"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="@string/mode_heat" />

        <TextView
            android:id="@+id/mode_fan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingTop="9dp"
            android:paddingBottom="9dp"
            android:gravity="center"
            android:background="@drawable/widget_chip_bg"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="@string/mode_fan" />
    </LinearLayout>

</LinearLayout>
